# anigraph environment configuration
#
# Copy this file to .env and fill in your API keys:
#   cp .env.example .env
#
# You only need keys for the providers you want to use.
# The pipeline skips enrichment phases when their key is missing.

# TMDB API read access token (JWT)
# Get one at https://www.themoviedb.org/settings/api
# Required for: TMDB enrichment (posters, backdrops, logos)
TMDB_READ_KEY=

# TheTVDB v4 API key
# Get one at https://thetvdb.com/api
# Required for: TVDB enrichment (episodes, artwork)
THETVDB_KEY=
